{
  "name": "genmem-mcp",
  "version": "0.1.5",
  "description": "Local-first markdown memory MCP server. Searchable, file-based, human-readable.",
  "type": "module",
  "license": "MIT",
  
  "publishConfig": {
  "access": "public"
},

  "author": {
    "name": "Jannatunnaim Sobuj",
    "url": "https://github.com/helloSobuj"
  },

  "homepage": "https://github.com/helloSobuj/genmem",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/helloSobuj/genmem.git"
  },

  "bugs": {
    "url": "https://github.com/helloSobuj/genmem/issues"
  },

  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/helloSobuj"
  },

  "bin": {
    "genmem-mcp": "./bin/genmem-mcp.js"
  },

  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE",
    "docs/"
  ],

  "engines": {
  "node": ">=22.12.0"
  },

  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "serve": "node --enable-source-maps dist/cli/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },

  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },

  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "fast-check": "^3.22.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.2"
  },

  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "claude",
    "cursor",
    "cline",
    "windsurf",
    "continue",
    "ai-memory",
    "long-term-memory",
    "knowledge-base",
    "markdown",
    "local-first",
    "rag",
    "mcp-server"
  ]
}
